#include <iostream>
#include <vector>
using namespace std;

class Solution {
public:
    string convertToRoman(int n) {

        vector<int> val = {1000,900,500,400,100,90,50,40,10,9,5,4,1};
        vector<string> sym = {"M","CM","D","CD","C","XC","L","XL","X","IX","V","IV","I"};

        string result = "";

        for(int i = 0; i < val.size(); i++) {

            int times = n / val[i];

            while(times--) {
                result += sym[i];
            }

            n = n % val[i];
        }

        return result;
    }
};

int main() {

    Solution obj;

    int num;
    cout << "Enter number: ";
    cin >> num;

    cout << "Roman Numeral: " << obj.convertToRoman(num) << endl;

    return 0;
}
